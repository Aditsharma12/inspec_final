# ──────────────────────────────────────────────────────────────────────────────
#  backend_vid  environment configuration
#  Copy this file to .env and fill in your values.
#  .env is git-ignored — never commit real tokens.
# ──────────────────────────────────────────────────────────────────────────────

# HuggingFace repo that holds the CViT weight file.
# Format: <username>/<repo-name>
# Example: myuser/cvit-deepfake-weights
#
# To upload your weight once:
#   pip install huggingface_hub
#   huggingface-cli login
#   huggingface-cli upload myuser/cvit-deepfake-weights \
#       weight/cvit2_deepfake_detection_ep_50.pth \
#       cvit2_deepfake_detection_ep_50.pth
#
HF_WEIGHT_REPO=YOUR_HF_USERNAME/cvit-deepfake-weights

# Optional: HuggingFace token (needed only if the repo is private)
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx
